# ============================================================
# credentials.auto.tfvars.example — Template for secret values
# ============================================================
# Copy this file to credentials.auto.tfvars and fill in your values.
# The real credentials file is excluded from Git via .gitignore.
# Uses .auto.tfvars so Terraform loads it automatically (no -var-file needed).

proxmox_api_url          = "https://<PROXMOX_IP>:8006"
proxmox_api_token_id     = "user@realm!tokenname"
proxmox_api_token_secret = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
ssh_public_key           = "ssh-ed25519 AAAA... user@host"
