# ============================================================
# credentials.pkrvars.hcl.example — Template for secret values
# ============================================================
# Copy this file to credentials.pkrvars.hcl and fill in your actual values.
# The real credentials file is excluded from Git via .gitignore.
#
# Usage: packer build -var-file=credentials.pkrvars.hcl .

proxmox_api_url          = "https://<PROXMOX_IP>:8006/api2/json"
proxmox_api_token_id     = "user@realm!tokenname"
proxmox_api_token_secret = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
ssh_password             = "your-temporary-build-password"
